# Copy to .env (which is gitignored) and fill in.
# Used by scripts/discover.py and any future standalone tools.

# iGarden / Fairland account credentials (same ones you use in the Madimack app).
FAIRLAND_USERNAME=you@example.com
FAIRLAND_PASSWORD=replace-me

# Two-letter country code your account is registered under.
# The heat-pump build defaults to "DE"; for Australia use "AU".
FAIRLAND_COUNTRY_CODE=AU

# Phone code used in the login payload. The API client defaults to "49" (Germany)
# but accepts an override. For AU use "61". Only matters at login time.
FAIRLAND_PHONE_CODE=61
